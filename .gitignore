# Ignore everything by default
/*

# But allow these:
!.gitignore
!README.md
!AGENTS.md
!CMakeLists.txt
!sdkconfig
!sdkconfig.defaults
!.github/
!.github/**
!main/
!Jetson Code/
!ML Notebook/ 
# Inside main/, ignore nothing (upload everything in there)
!main/**
!Jetson Code/**
!ML Notebook/** 

# Exclude large Docker image archives
Jetson Code/Docker/*.tar
Jetson Code/models/
Jetson Code/blobs/*

# Local secrets/config for Jetson runtime
Jetson Code/Code/config.py
Jetson Code/Code/Config.py

!CI Pipeline Code/
CI Pipeline Code/images/*

!CI Pipeline Code/
CI Pipeline Code/images/*

# Local secrets/config for firmware
main/configs.c
main/configs.h

Jetson Code/edith-glasses_jp64.tar
Jetson Code/index.json
Jetson Code/manifest.json
Jetson Code/oci-layout
Jetson Code/repositories

# OS/editor/runtime junk
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
*.swo
*.tmp
*.temp
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
ML Notebook/captures/mp4/**
.gitignore
