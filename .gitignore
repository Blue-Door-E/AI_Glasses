# Ignore everything by default
/*

# But allow these:
!.gitignore
!README.md
!AGENTS.md
!CMakeLists.txt
!sdkconfig
!sdkconfig.defaults
!.github/
!.github/**
!main/
!Jetson Code/
# Inside main/, ignore nothing (upload everything in there)
!main/**
!Jetson Code/**

# Exclude large Docker image archives
Jetson Code/Docker/*.tar
Jetson Code/models/
# Local secrets/config for Jetson runtime
Jetson Code/Code/config.py
Jetson Code/Code/Config.py
Jetson Code/Code/__pycache__

# Local secrets/config for firmware
main/configs.c
main/configs.h
